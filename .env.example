# ─── App URLs ───────────────────────────────────────────────────────────────
# Public portal origin (links in emails, PWA, redirects)
NEXT_PUBLIC_PORTAL_URL=https://portal.alphasolutions.software
# Marketing site origin (email footer / branding links)
NEXT_PUBLIC_SITE_URL=https://www.alphasolutions.software

# ─── Supabase (same project as the marketing site) ──────────────────────────
# Project URL from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Anon / public key (safe for browser; RLS enforced)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key (server only — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Admin / owner allowlists ───────────────────────────────────────────────
# Comma-separated emails that can access /admin (staff + owners)
ADMIN_EMAILS=owner@example.com,staff@example.com
# Comma-separated owners (revenue reports + staff management). Falls back to ADMIN_EMAILS if unset.
OWNER_EMAILS=owner@example.com

# ─── Sanity CMS (same project as marketing) ─────────────────────────────────
# Sanity project ID
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
# Sanity dataset name
NEXT_PUBLIC_SANITY_DATASET=production

# ─── SMTP (Nodemailer transactional email) ──────────────────────────────────
# SMTP hostname (e.g. smtp.gmail.com or your provider)
SMTP_HOST=smtp.example.com
# SMTP port (587 STARTTLS or 465 SSL)
SMTP_PORT=587
# Set true only when using port 465 SSL
SMTP_SECURE=false
# SMTP auth username
SMTP_USER=your_smtp_user
# SMTP auth password / app password
SMTP_PASS=your_smtp_password
# From header shown to recipients
SMTP_FROM=Alpha Solutions <no-reply@alphasolutions.software>
# Ops inbox(es) for admin alerts (comma-separated)
AUTH_OPS_NOTIFY_EMAIL=ops@example.com
# Optional absolute URL for email header logo (defaults to portal /alpha-logo.png)
EMAIL_LOGO_URL=

# ─── Groq (Alpha Assistant — server-side only) ──────────────────────────────
# Groq API key for chat + assist drafts
GROQ_API_KEY=your_groq_api_key
# Model id (default llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Scheduling (optional) ──────────────────────────────────────────────────
# Public Cal.com booking page shown in Schedule tab
NEXT_PUBLIC_CAL_COM_URL=https://cal.com/your-link
# Server-side alias for the same Cal.com URL (optional)
CAL_COM_URL=
